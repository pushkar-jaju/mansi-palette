generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PaintingStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum CommissionStatus {
  PENDING
  QUOTE_SENT
  APPROVED
  IN_PROGRESS
  READY_FOR_SHIPPING
  SHIPPED
  DELIVERED
  REJECTED
}

model User {
  id                       String              @id @default(cuid())
  name                     String
  email                    String              @unique
  passwordHash             String
  role                     Role                @default(USER)
  emailVerified            Boolean             @default(false)
  verificationToken        String?             @unique
  verificationTokenExpires DateTime?
  phone                    String?
  profilePicture           String?
  savedAddresses           String[]            @default([])
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  orders                   Order[]
  commissions              CommissionRequest[]
  reviews                  Review[]
  wishlist                 WishlistItem[]
}

model Painting {
  id          String         @id @default(cuid())
  title       String
  description String
  imageUrl        String
  imagePublicId   String?
  images          String[]       @default([])
  imagesPublicIds String[]       @default([])
  price       Float
  width       Float          // in inches
  height      Float          // in inches
  medium      String         // e.g. Oil, Acrylic, Watercolor, Mixed Media
  canvasType  String         // e.g. Stretched Canvas, Paper, Wood Panel
  frameOption String         // e.g. Framed, Unframed, Stretched Canvas (Ready to Hang)
  category    String         // e.g. Landscape, Abstract, Floral, Coastal, Portrait
  status      PaintingStatus @default(AVAILABLE)
  isFeatured  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orderItems  OrderItem[]
  reviews     Review[]
  wishlist    WishlistItem[]
}

model Order {
  id              String               @id @default(cuid())
  userId          String?
  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  totalAmount     Float
  paymentStatus   String               @default("PENDING") // PENDING, PAID, FAILED
  paymentId       String?              // Razorpay Payment ID or Transaction ID
  status          String               @default("PENDING_APPROVAL") // PENDING_APPROVAL, ACCEPTED, PAYMENT_PENDING, PAYMENT_RECEIVED, PROCESSING, SHIPPED, DELIVERED, REJECTED
  courierName     String?

  trackingNumber  String?
  items           OrderItem[]
  timeline        OrderTimelineEvent[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paintingId String
  painting   Painting @relation(fields: [paintingId], references: [id])
  price      Float
  createdAt  DateTime @default(now())
}

model CommissionRequest {
  id               String           @id @default(cuid())
  userId           String?
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  clientName       String
  clientEmail      String
  clientPhone      String
  title            String
  description      String
  width            Float
  height           Float
  budget           Float
  quoteAmount      Float?
  progress         Int?             @default(0)
  referenceUrl     String?          // URL to reference image
  status           CommissionStatus @default(PENDING)
  notes            String?          // Admin notes or response
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model OrderTimelineEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdAt DateTime @default(now())
}

model Review {
  id         String    @id @default(cuid())
  paintingId String?
  painting   Painting? @relation(fields: [paintingId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String
  authorEmail String
  rating     Int
  comment    String
  status     String    @default("PENDING") // PENDING, APPROVED, SPAM
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model StoreSettings {
  id                    String   @id @default("default")
  storeName             String   @default("Mansi's Palette")
  storeLogo             String?
  contactEmail          String   @default("mansipalette@gmail.com")
  contactPhone          String   @default("+91 98765 43210")
  contactAddress        String   @default("Mumbai, India")
  instagramUrl          String   @default("https://instagram.com/mansispalette")
  facebookUrl           String   @default("https://facebook.com/mansispalette")
  pinterestUrl          String   @default("https://pinterest.com/mansispalette")
  baseShippingCost      Float    @default(150.0)
  freeShippingThreshold Float    @default(5000.0)
  estimatedDeliveryDays Int      @default(7)
  notifyOnNewOrder      Boolean  @default(true)
  notifyOnNewCommission Boolean  @default(true)
}

model WishlistItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paintingId String
  painting   Painting @relation(fields: [paintingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([userId, paintingId])
}